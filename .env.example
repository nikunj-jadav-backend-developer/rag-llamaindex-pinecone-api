# ─── Groq (LLM) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=your-groq_llm_model_here
GROQ_LLM_TEMPERATURE = 0.4

HF_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSION=384

# ─── Pinecone (Vector Store) ───────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=your_pinecone_index_name
PINECONE_EMBEDDING_DIMENSION=your_embedding_dimension_here  
PINECONE_METRIC=your_distance_metric_here  # e.g., "cosine", "euclidean", "dotproduct"
PINECONE_CLOUD=your_pinecone_cloud_here
PINECONE_REGION=your_pinecone_region_here

# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=RAG LlamaIndex Pinecone API
APP_VERSION=1.0.0
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_FILE_EXTENSIONS=["pdf","txt"]
ALLOWED_MIME_TYPES=["application/pdf","text/plain"]

# ─── Text Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE = 1024
CHUNK_OVERLAP = 100